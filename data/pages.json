        "illustrate_main": "※ 核心規則：僅上市個股，需同時滿足以下條件。建議短線觀測週期約 2 週。",
        "illustrate": [
            {
                "condition": "基礎量能門檻",
                "content": "20日均量 > 700,000(股)。確保流動性充足，排除成交量過低的殭屍股。"
            },
            {
                "condition": "攻擊量能確認",
                "content": "今日量 > 5日均量 且 5日均量 > 20日均量（量增趨勢），或 今日量 > 20日均量 1.3 倍(爆量趨勢)。"
            },
            {
                "condition": "極致洗盤確認 (重要)",
                "content": "昨日成交量 < 5日均量，且昨日震幅 < 3.5%。代表發動前籌碼經過極度壓抑與洗盤。"
            },
            {
                "condition": "價穩冷靜型態",
                "content": "昨日 K 線實體 < 3% 且收盤高於 20日線。確認股價在生命線之上進行「窄幅整理」，而非破位大跌。"
            },
            {
                "condition": "籌碼集中強度",
                "content": "今日法人集中度：若未放量需 > 6%，若放量需 > 8%。代表當日籌碼主要由大戶收購。"
            },
            {
                "condition": "波段位階保護",
                "content": "10日位階處於 20%~90% 之間。避開絕對高檔噴發末端，也避開剛破底的弱勢股。"
            },
            {
                "condition": "短期籌碼積累",
                "content": "5日累計法人集中度 > 3%。確保法人不是只買一天（隔日沖），而是具備連續佈局。"
            }
